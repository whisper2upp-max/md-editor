{
  "name": "md-editor",
  "private": true,
  "version": "0.5.3",
  "type": "module",
  "description": "A WYSIWYG Markdown editor with comment navigation, packaged as a single self-contained HTML file.",
  "author": "Wesley Yan",
  "license": "MIT",
  "keywords": [
    "markdown",
    "markdown-editor",
    "wysiwyg",
    "comment-navigation",
    "milkdown",
    "single-file",
    "offline"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild.mjs",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.0",
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/kit": "^7.21.2",
    "codemirror": "^6.0.2",
    "idb-keyval": "^6.2.6",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.0"
  }
}
